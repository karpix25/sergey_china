# Google Cloud
GOOGLE_API_KEY=your_google_cloud_api_key
GCS_BUCKET_NAME=your_bucket_name
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1
# Service Account credentials as JSON string (no file needed, safe for GitHub/Docker)
# Copy the entire contents of your service-account.json and paste it here as one line:
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'

